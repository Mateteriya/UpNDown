{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Up&Down — игра в сети",
  "version": "1.0.0",
  "identifier": "com.updown.host.lan",
  "build": {
    "beforeDevCommand": "npm run host:desktop:dev --prefix ..",
    "devUrl": "http://127.0.0.1:3001/host",
    "beforeBuildCommand": "npm run host:desktop:prep --prefix ..",
    "frontendDist": "../server/public"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Up&Down — игра в сети",
        "width": 440,
        "height": 720,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.ico"],
    "shortDescription": "Создайте комнату в вашей Wi‑Fi",
    "longDescription": "Сервер Up&Down для игры с телефонов в одной сети Wi‑Fi. QR и код комнаты. Без установки Node.js.",
    "resources": {
      "bundle/": "../bundle/"
    },
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico"
      }
    }
  }
}
