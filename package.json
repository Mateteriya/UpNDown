{
  "name": "up-down",
  "version": "0.1.0",
  "description": "Мультиплатформенное приложение для карточной игры Up&Down",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:host": "vite --host",
    "dev:cosmo": "vite --port 5199 --open /cosmogenesis-demo.html",
    "build": "node scripts/gen-favicon.mjs && tsc && vite build",
    "preview": "vite preview",
    "preview:host": "vite preview --host",
    "test": "vitest",
    "exact-order-star-offset": "node tools/exact-order-star-flash-offset.mjs",
    "cap:sync": "npm run build && npx cap sync android",
    "cap:open": "npx cap open android",
    "handbook:dev": "npm run dev --prefix docs-site",
    "handbook:build": "npm run build --prefix docs-site",
    "handbook:preview": "npm run preview --prefix docs-site",
    "server:install": "npm install --prefix server",
    "server:dev": "npm run dev --prefix server",
    "server:start": "npm run start --prefix server",
    "host:panel": "npm run server:dev",
    "build:host-game": "node scripts/gen-favicon.mjs && vite build --config vite.host.config.ts",
    "host:kill": "powershell -ExecutionPolicy Bypass -File scripts/kill-host-ports.ps1",
    "host:app": "node scripts/host-open-browser.mjs",
    "host:desktop:dev": "node scripts/host-desktop-dev.mjs",
    "host:desktop:prep": "node scripts/host-desktop-prep.mjs",
    "host:desktop:install": "npm install --prefix host-desktop",
    "host:desktop": "npm run host:desktop:install && cd host-desktop && npm run tauri dev",
    "host:desktop:build": "npm run host:desktop:install && cd host-desktop && npm run tauri build",
    "host:installer:prep": "node scripts/stage-host-installer.mjs"
  },
  "dependencies": {
    "@capacitor/android": "^8.0.2",
    "@capacitor/cli": "^8.0.2",
    "@capacitor/core": "^8.0.2",
    "@supabase/supabase-js": "^2.45.0",
    "react": "^18.2.0",
    "react-colorful": "^5.7.0",
    "react-dom": "^18.2.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.2.1",
    "esbuild": "^0.25.12",
    "png-to-ico": "^3.0.0",
    "sql.js": "^1.14.0",
    "supabase": "^2.95.3",
    "typescript": "^5.3.3",
    "vite": "^5.0.10",
    "vite-plugin-pwa": "^0.20.0",
    "vitest": "^1.1.0"
  }
}
